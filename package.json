{
  "name": "technology",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "data:pull": "node ./scripts/sync-private-data.mjs pull",
    "data:push": "node ./scripts/sync-private-data.mjs push",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run check:markdown-pages && astro build && npm run check:markdown-pages:dist",
    "preview": "astro preview",
    "check": "npm run check:markdown-pages && astro check",
    "check:markdown-pages": "node ./scripts/verify-markdown-page-pairs.mjs",
    "check:markdown-pages:dist": "node ./scripts/verify-markdown-page-pairs.mjs --dist",
    "prepare": "node ./scripts/install-git-hooks.mjs"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "^24.6.1",
    "astro": "7.1.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "yaml": "^2.8.3"
  }
}
