---
import StandardHeader from "./StandardHeader.astro";
import {
  getStandardPageNavGroups,
  type StandardPageKey,
} from "../lib/standard-page-nav";
import { withBasePath } from "../lib/site-url";

export interface HeaderNavItem {
  href?: string;
  label: string;
  current?: boolean;
}

export interface Props {
  currentPage?: StandardPageKey;
  showSearch?: boolean;
  searchAction?: string;
  searchPlaceholder?: string;
  searchQuery?: string;
  sectionNavItems?: HeaderNavItem[];
  sectionNavLabel?: string;
  sectionTrailItems?: HeaderNavItem[];
  sectionTrailLabel?: string;
}

const {
  currentPage,
  showSearch = true,
  searchAction = withBasePath("/tech-radar/"),
  searchPlaceholder = "Search",
  searchQuery = "",
  sectionNavItems = [],
  sectionNavLabel = "Section",
  sectionTrailItems = [],
  sectionTrailLabel = "Path",
} = Astro.props;
---

<StandardHeader
  navGroups={getStandardPageNavGroups(currentPage)}
  showSearch={showSearch}
  searchAction={searchAction}
  searchPlaceholder={searchPlaceholder}
  searchQuery={searchQuery}
  sectionNavItems={sectionNavItems}
  sectionNavLabel={sectionNavLabel}
  sectionTrailItems={sectionTrailItems}
  sectionTrailLabel={sectionTrailLabel}
/>
