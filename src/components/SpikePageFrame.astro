---
import StandardPageHeader, { type HeaderNavItem } from "./StandardPageHeader.astro";
import StandardPageIntro, { type IntroPill } from "./StandardPageIntro.astro";
import { withBasePath } from "../lib/site-url";

export interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  pills?: IntroPill[];
  searchAction?: string;
  searchPlaceholder?: string;
  sectionNavItems?: HeaderNavItem[];
  sectionTrailItems?: HeaderNavItem[];
}

const {
  eyebrow,
  title,
  summary,
  pills = [],
  searchAction = withBasePath("/spikes/format-architecture/"),
  searchPlaceholder = "Search spike pages",
  sectionNavItems = [],
  sectionTrailItems = [],
} = Astro.props;
---

<div class="shell shell-narrow standard-page shell-spike">
  <StandardPageHeader
    showSearch={false}
    searchAction={searchAction}
    searchPlaceholder={searchPlaceholder}
    sectionNavItems={sectionNavItems}
    sectionNavLabel="Spike pages"
    sectionTrailItems={sectionTrailItems}
    sectionTrailLabel="Spike route"
  />

  <StandardPageIntro
    eyebrow={eyebrow}
    title={title}
    summary={summary}
    pills={pills}
    className="standard-page-intro-detail"
  />

  <slot />
</div>
