---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "e*f(x) Technology",
  description = "Technology platform, standards, and radar for e*f(x).",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%23333e48'/%3E%3Ctext x='32' y='43' text-anchor='middle' font-family='Arial' font-size='28' font-weight='700' fill='white'%3Efx%3C/text%3E%3C/svg%3E" />
    <script is:inline>
      (() => {
        const storageKey = "efx-site-theme";

        try {
          const storedTheme = window.localStorage.getItem(storageKey);
          const preferredTheme =
            storedTheme === "light" || storedTheme === "dark"
              ? storedTheme
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";

          document.documentElement.dataset.theme = preferredTheme;
          document.documentElement.style.colorScheme = preferredTheme;
        } catch {
          const fallbackTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          document.documentElement.dataset.theme = fallbackTheme;
          document.documentElement.style.colorScheme = fallbackTheme;
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,300..700,0,0"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to dark mode" title="Switch to dark mode">
      <span class="material-symbols-rounded theme-toggle-icon" data-theme-toggle-icon aria-hidden="true">dark_mode</span>
      <span class="theme-toggle-label" data-theme-toggle-label>Dark mode</span>
    </button>
    <slot />
    <script>
      import { initThemeToggle } from "../scripts/theme-toggle.ts";
      import { initCodeCopyButtons } from "../scripts/code-copy.ts";

      initThemeToggle();
      initCodeCopyButtons();
    </script>
  </body>
</html>
