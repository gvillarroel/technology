---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StandardPageHeader from "../../components/StandardPageHeader.astro";
import { getAiMetricsDemoDataset } from "../../lib/ai-metrics-demo";
import {
  getAiSdlcData,
  getAiSdlcDetailHtmlUrl,
  getAiSdlcResolvedToolGroups,
  getAiSdlcTopicBySlug,
  getAiSdlcTopics,
} from "../../lib/ai-sdlc";
import { formatSkillPassRatio } from "../../lib/skills-page";
import { getSkillDetailHtmlUrl, getSkillsCatalogData } from "../../lib/skills-repositories";
import { withBasePath } from "../../lib/site-url";

export async function getStaticPaths() {
  const topics = await getAiSdlcTopics();

  return topics.map((topic) => ({
    params: {
      slug: topic.slug,
    },
  }));
}

const { slug } = Astro.params;
const { overview } = await getAiSdlcData();
const topic = slug ? await getAiSdlcTopicBySlug(slug) : undefined;
const topics = await getAiSdlcTopics();
const skillsCatalog = topic?.slug === "skills" ? await getSkillsCatalogData() : undefined;
const metricsDataset = topic?.slug === "metrics" ? await getAiMetricsDemoDataset() : undefined;
const skillsPageCopy = topic?.skillsPage;
const harnessToolGroups = topic?.slug === "harness-tools" ? await getAiSdlcResolvedToolGroups(topic) : undefined;
const harnessTools = harnessToolGroups?.flatMap((group) => group.tools) ?? [];
const harnessCycleMermaid = `
flowchart LR
  A["Generate Code"] --> B["Validate Changes"]
  B --> C["Release And Rollout"]
  C --> D["Verify In Production"]
  D --> A
`;

function getPrimarySkillLink(skill: NonNullable<typeof skillsCatalog>["skills"][number]) {
  if (skill.sourceUrl) {
    return {
      href: skill.sourceUrl,
      label: skillsPageCopy?.sourceLinkLabel,
    };
  }

  if (skill.repositoryUrl) {
    return {
      href: skill.repositoryUrl,
      label: skillsPageCopy?.repositoryLinkLabel,
    };
  }

  return null;
}

if (!topic) {
  return Astro.redirect(withBasePath("/ai-sdlc/"));
}

const aiSdlcSectionNavItems = [
  {
    href: withBasePath("/ai-sdlc/"),
    label: "Overview",
    current: false,
  },
  ...topics.map((entry) => ({
    href: getAiSdlcDetailHtmlUrl(entry.slug),
    label: entry.name,
    current: entry.slug === topic.slug,
  })),
];
---

<BaseLayout
  title={`${topic.name} | ${overview.title} | e*f(x) Technology`}
  description={topic.summary}
>
  <main class="shell shell-narrow standard-page">
    <StandardPageHeader
      currentPage="ai-sdlc"
      searchAction={withBasePath("/ai-sdlc/")}
      searchPlaceholder={overview.copy.searchPlaceholder}
      searchQuery={topic.name}
      sectionNavItems={aiSdlcSectionNavItems}
      sectionNavLabel="AI SDLC sections"
    />

    <section class="standard-page-intro standard-page-intro-detail">
      <div>
        <p class="eyebrow">{overview.copy.detailEyebrowPrefix} / {topic.status}</p>
        <h1 class="standard-page-title">{topic.name}</h1>
        <p class="copy standard-copy-wide">{topic.summary}</p>
      </div>
    </section>

    {topic.slug === "skills" && skillsCatalog ? (
      <>
        <section class="standard-toolbar skills-toolbar" aria-label="Skills filters">
          <div class="radar-control">
            <label class="standard-label" for="skills-search">{skillsPageCopy?.filterSearchLabel}</label>
            <input
              id="skills-search"
              class="standard-select"
              type="search"
              placeholder={skillsPageCopy?.filterSearchPlaceholder}
            />
          </div>
          <label class="skills-toggle" for="skills-evaluated-only">
            <span class="skills-toggle-copy">
              <span class="standard-label">{skillsPageCopy?.filterToggleLabel}</span>
              <span class="skills-toggle-hint">{skillsPageCopy?.filterToggleHint}</span>
            </span>
            <span class="skills-toggle-control">
              <input id="skills-evaluated-only" type="checkbox" />
              <span class="skills-toggle-track" aria-hidden="true"></span>
            </span>
          </label>
        </section>

        <section class="standard-section-heading">
          <div>
            <p class="eyebrow">{skillsPageCopy?.catalogEyebrow}</p>
            <h2>{skillsPageCopy?.catalogHeading}</h2>
          </div>
          <p
            class="standard-section-meta"
            id="skills-results-count"
            data-results-count-suffix={skillsPageCopy?.resultsCountSuffix}
          >
            {skillsCatalog.skills.length} {skillsPageCopy?.resultsCountSuffix}
          </p>
        </section>

        <section class="bat-list" id="skills-list">
          {skillsCatalog.skills.map((skill, index) => {
            const primarySkillLink = getPrimarySkillLink(skill);

            return (
              <article
                class="bat-card bat-entry skills-entry"
                data-repository={skill.repositorySlug}
                data-tags={skill.tags.join("|")}
                data-search={skill.searchText}
                data-evaluated={skill.evaluationSummary.evaluated ? "true" : "false"}
              >
              <div class="bat-card-bar">
                <a class="skills-card-file-link" href={getSkillDetailHtmlUrl(skill.repositorySlug, skill.slug)}>
                  <span class="bat-card-file" data-highlight-text>{skill.relativePath}/SKILL.md</span>
                </a>
                <span class="skills-repository-pill" data-highlight-text>{skill.repositoryName}</span>
              </div>

              <div class="bat-card-body bat-card-body-stack">
                <div class="bat-line">
                  <span class="bat-gutter">{index * 3 + 1}</span>
                  <div class="bat-code">
                    <p class="bat-copy" data-highlight-text>{skill.description}</p>
                  </div>
                </div>
                <div class="bat-line">
                  <span class="bat-gutter">{index * 3 + 2}</span>
                  <div class="bat-code bat-meta-row">
                    <span class={`skills-evaluation-pill ${skill.evaluationSummary.evaluated ? "is-evaluated" : "is-not-evaluated"}`}>
                      {skill.evaluationSummary.evaluated ? skillsPageCopy?.statusEvaluated : skillsPageCopy?.statusNotEvaluated}
                    </span>
                    {skill.evaluationSummary.evaluated ? <span>{formatSkillPassRatio(skill.evaluationSummary.averageSuccessRatio)}</span> : null}
                    <a href={getSkillDetailHtmlUrl(skill.repositorySlug, skill.slug)}>{skillsPageCopy?.detailLinkLabel}</a>
                  </div>
                </div>
                <div class="bat-line">
                  <span class="bat-gutter">{index * 3 + 3}</span>
                  <div class="bat-code">
                    <p class="bat-heading bat-heading-inline">{skillsPageCopy?.installHeading}</p>
                    <pre class="skills-install-code"><code data-highlight-text>{skill.installAvailable ? skill.installSnippet : skillsPageCopy?.installUnavailableSnippet}</code></pre>
                    {primarySkillLink ? (
                      <div class="bat-link-row">
                        <a href={primarySkillLink.href}>{primarySkillLink.label}</a>
                      </div>
                    ) : null}
                  </div>
                </div>
              </div>
              </article>
            );
          })}
        </section>

        <p class="standard-empty-state" id="skills-empty-state" hidden>
          {skillsPageCopy?.emptyState}
        </p>
      </>
    ) : topic.slug === "harness-tools" && harnessToolGroups ? (
      <>
        <section class="harness-cycle-grid">
          <article class="bat-card harness-cycle-card harness-cycle-card-full">
            <div class="bat-card-bar">
              <span class="bat-card-file">ai-sdlc-cycle.mmd</span>
              <span class="bat-card-lang">mmd</span>
            </div>

            <div class="bat-card-body bat-card-body-stack">
              <div class="bat-line">
                <span class="bat-gutter">1</span>
                <div class="bat-code">
                  <p class="bat-heading">Software delivery cycle</p>
                  <p class="bat-copy">
                    Read this page from left to right: generate code, validate the change, release
                    it through controlled delivery, and confirm behavior in production before the
                    next iteration.
                  </p>
                  <pre class="bat-mermaid-diagram mermaid" aria-label="AI SDLC harness tools cycle">
{harnessCycleMermaid}
                  </pre>
                </div>
              </div>
            </div>
          </article>
        </section>

        <section class="standard-section-heading">
          <div>
            <p class="eyebrow">Tools By Stage</p>
            <h2>Harness tools across the SDLC cycle</h2>
          </div>
          <p class="standard-section-meta">{harnessTools.length} radar-backed tools</p>
        </section>

        <section class="harness-tools-groups" id="harness-tools-groups">
          {harnessToolGroups.map((group) => (
            <article class="harness-tools-group" data-group-title={group.title.toLowerCase()}>
              <div class="harness-tools-group-header">
                <div>
                  <p class="eyebrow">{group.title}</p>
                  <h3>{group.summary}</h3>
                </div>
                <p class="standard-section-meta harness-tools-group-count">
                  {group.tools.length} tools in this stage
                </p>
              </div>

              <div class="harness-tools-grid">
                {group.tools.map((tool) => (
                  <article class="harness-tool-box">
                    <div class="harness-tool-box-topline">
                      <a class="skills-card-file-link" href={withBasePath(`/tech-radar/${tool.entry.slug}/`)}>
                        <span class="bat-card-file">{tool.entry.name}</span>
                      </a>
                      <span class={`harness-ring-pill harness-ring-pill-${tool.entry.ring.toLowerCase().replace(/\s+/g, "-")}`}>
                        {tool.entry.ring}
                      </span>
                    </div>

                    <div class="harness-tool-box-body">
                      <p class="ai-sdlc-card-copy">{tool.entry.summary}</p>
                      <div class="skills-metadata-list">
                        <span class="skills-metadata-pill">scope: {tool.entry.primaryScope}</span>
                        <span class="skills-metadata-pill">owner: {tool.entry.owner}</span>
                        <span class="skills-tag-pill is-muted">status: {tool.entry.status}</span>
                      </div>
                      <p class="bat-heading bat-heading-inline">Role in this stage</p>
                      <p class="ai-sdlc-card-copy">{tool.role}</p>
                      <div class="skills-metadata-list">
                        <span class="skills-metadata-pill">focus: {tool.focus}</span>
                        <span class="skills-tag-pill is-muted">updated: {tool.entry.updated}</span>
                      </div>
                      <p class="bat-heading bat-heading-inline">Production signal</p>
                      <p class="ai-sdlc-card-copy">{tool.productionSignal}</p>
                      <div class="bat-link-row">
                        <a href={withBasePath(`/tech-radar/${tool.entry.slug}/`)}>open tech radar detail</a>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </article>
          ))}
        </section>
      </>
    ) : topic.slug === "metrics" && metricsDataset ? (
      <>
        <section class="metrics-demo-top" id="metrics-demo-top">
          <div class="radar-floating-rail-anchor" id="metrics-team-rail-anchor">
            <aside class="standard-floating-rail is-inline-top has-readable-surface" id="metrics-team-rail" aria-label="Metrics team filters">
              <div class="standard-floating-rail-inner">
                <div class="radar-top-filters">
                  <div class="radar-control metrics-team-control">
                    <span class="standard-label">Teams</span>
                    <div class="metrics-team-multiselect" id="metrics-team-filter">
                      <button
                        class="standard-select metrics-team-trigger"
                        id="metrics-team-trigger"
                        type="button"
                        aria-expanded="false"
                        aria-controls="metrics-team-panel"
                      >
                        <span class="metrics-team-trigger-text">
                          <span class="metrics-team-trigger-value" id="metrics-team-filter-label">All teams</span>
                          <span class="metrics-team-trigger-hint">10 teams available</span>
                        </span>
                        <span class="metrics-team-trigger-icon" aria-hidden="true">▾</span>
                      </button>

                      <div class="metrics-team-panel" id="metrics-team-panel" hidden>
                        <div class="metrics-team-panel-topline">
                          <input
                            id="metrics-team-search"
                            class="standard-select metrics-team-search"
                            type="search"
                            placeholder="Search teams"
                            autocomplete="off"
                          />
                          <button class="standard-toggle-button metrics-team-reset" type="button" data-team-filter="all">
                            All teams
                          </button>
                        </div>

                        <div class="metrics-team-options" id="metrics-team-options">
                          {metricsDataset.teams.map((team) => (
                            <label class="metrics-team-option" data-team-option={team.slug} data-search={team.name.toLowerCase()}>
                              <input class="metrics-team-checkbox" type="checkbox" value={team.slug} />
                              <span class="metrics-team-option-swatch" style={`background:${team.color};`}></span>
                              <span class="metrics-team-option-name">{team.name}</span>
                            </label>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="radar-control">
                    <label class="standard-label" for="metrics-start-date">Start date</label>
                    <input id="metrics-start-date" class="standard-select metrics-date-input" type="date" />
                  </div>

                  <div class="radar-control">
                    <label class="standard-label" for="metrics-end-date">End date</label>
                    <input id="metrics-end-date" class="standard-select metrics-date-input" type="date" />
                  </div>

                  <div class="radar-control">
                    <span class="standard-label">Scale</span>
                    <div class="standard-toggle-group standard-toggle-group-vertical" id="metrics-value-mode">
                      <button class="standard-toggle-button is-active" type="button" data-value-mode="total">
                        Total
                      </button>
                      <button class="standard-toggle-button" type="button" data-value-mode="ratio">
                        Ratio
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </aside>
          </div>

          <div class="metrics-demo-top-content">
            <div class="radar-floating-rail-dock" id="metrics-team-rail-dock" aria-hidden="true"></div>
          </div>
        </section>

        <section class="standard-section-heading">
          <div>
            <p class="eyebrow">Usage Distribution</p>
            <h2>Users by coding assistant</h2>
          </div>
          <p class="standard-section-meta" id="metrics-selection-meta">All 10 teams in view</p>
        </section>

        <section class="bat-grid bat-grid-detail metrics-hero-grid">
          <article class="bat-card bat-card-wide">
            <div class="bat-card-bar">
              <span class="bat-card-file">platform-users.json</span>
              <span class="bat-card-lang">json</span>
            </div>

            <div class="bat-card-body bat-card-body-stack">
              <div class="bat-line">
                <span class="bat-gutter">1</span>
                <div class="bat-code">
                  <p class="bat-heading">Platform usage distribution</p>
                  <p class="bat-copy">
                    First view: stacked users for GitHub Copilot, Claude Code, and OpenAI Codex across the selected teams, with each team preserved as a distinct color and switchable between totals and normalized ratios.
                  </p>
                </div>
              </div>
              <div class="bat-line">
                <span class="bat-gutter">2</span>
                <div class="bat-code">
                  <div class="metrics-platform-chart" id="metrics-platform-chart"></div>
                </div>
              </div>
            </div>
          </article>

          <article class="bat-card">
            <div class="bat-card-bar">
              <span class="bat-card-file">selection-summary.json</span>
              <span class="bat-card-lang">json</span>
            </div>

            <div class="bat-card-body bat-card-body-stack">
              <div class="bat-line">
                <span class="bat-gutter">1</span>
                <div class="bat-code">
                  <dl class="bat-definition-list metrics-summary-list">
                    <div>
                      <dt>teams</dt>
                      <dd id="metrics-summary-teams">{metricsDataset.teams.length}</dd>
                    </div>
                    <div>
                      <dt>repositories</dt>
                      <dd id="metrics-summary-repositories">
                        {metricsDataset.teams.reduce((total, team) => total + team.repositories.length, 0)}
                      </dd>
                    </div>
                    <div>
                      <dt>monthly sessions</dt>
                      <dd id="metrics-summary-sessions">
                        {metricsDataset.teams.reduce((total, team) => total + team.metrics.monthlySessions, 0)}
                      </dd>
                    </div>
                    <div>
                      <dt>estimated spend</dt>
                      <dd id="metrics-summary-spend">
                        ${metricsDataset.teams.reduce((total, team) => total + team.metrics.estimatedMonthlySpendUsd, 0)}
                      </dd>
                    </div>
                  </dl>
                </div>
              </div>
            </div>
          </article>
          </section>

          <section class="standard-section-heading">
            <div>
              <p class="eyebrow">Repository Distribution</p>
              <h2>Repositories by team</h2>
            </div>
            <p class="standard-section-meta">Same selection, shown as totals or share of visible repositories</p>
          </section>

          <section class="bat-grid bat-grid-detail metrics-full-width-chart-grid">
            <article class="bat-card bat-card-wide">
              <div class="bat-card-bar">
                <span class="bat-card-file">team-repositories.json</span>
                <span class="bat-card-lang">json</span>
              </div>

              <div class="bat-card-body bat-card-body-stack">
                <div class="bat-line">
                  <span class="bat-gutter">1</span>
                  <div class="bat-code">
                    <p class="bat-heading">Repository distribution by team</p>
                    <p class="bat-copy">
                      Second view: repository counts for the currently selected teams, using the
                      same team color mapping as the platform chart. Ratio mode normalizes against
                      the total repositories in the visible selection.
                    </p>
                  </div>
                </div>
                <div class="bat-line">
                  <span class="bat-gutter">2</span>
                  <div class="bat-code">
                    <div class="metrics-platform-chart metrics-repository-chart" id="metrics-repository-chart"></div>
                  </div>
                </div>
              </div>
              </article>
            </section>

            <section class="standard-section-heading">
              <div>
                <p class="eyebrow">Model Distribution</p>
                <h2>Models used by team</h2>
              </div>
              <p class="standard-section-meta">Simulated distribution from current model families tracked in models.dev</p>
            </section>

            <section class="bat-grid bat-grid-detail metrics-full-width-chart-grid">
              <article class="bat-card bat-card-wide">
                <div class="bat-card-bar">
                  <span class="bat-card-file">team-models.json</span>
                  <span class="bat-card-lang">json</span>
                </div>

                <div class="bat-card-body bat-card-body-stack">
                  <div class="bat-line">
                    <span class="bat-gutter">1</span>
                    <div class="bat-code">
                      <p class="bat-heading">Model distribution by team</p>
                      <p class="bat-copy">
                        Third view: modeled usage across GPT-5, GPT-5 Mini, Claude Sonnet 4, Claude
                        Opus 4, and Claude Haiku 3.5. The model set was chosen from model families
                        currently listed on models.dev and distributed across teams as an
                        organizational demo. Hover a segment to inspect users, sessions, and
                        simulated monthly tokens for each team.
                      </p>
                    </div>
                  </div>
                  <div class="bat-line">
                    <span class="bat-gutter">2</span>
                    <div class="bat-code">
                      <div class="metrics-platform-chart metrics-model-chart" id="metrics-model-chart"></div>
                    </div>
                  </div>
                </div>
              </article>
            </section>

        </>
      ) : (
      <>
        <section class="bat-grid bat-grid-detail">
          <article class="bat-card bat-card-wide">
            <div class="bat-card-bar">
              <span class="bat-card-file">{overview.copy.signalsFile}</span>
              <span class="bat-card-lang">md</span>
            </div>

            <div class="bat-card-body bat-card-body-stack">
              <div class="bat-line">
                <span class="bat-gutter">1</span>
                <div class="bat-code">
                  <p class="bat-heading bat-heading-inline">{overview.copy.signalsHeading}</p>
                  <ul class="bat-list-block">
                    {topic.signals.map((signal) => <li>{signal}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="bat-card">
            <div class="bat-card-bar">
              <span class="bat-card-file">{overview.copy.metadataFile}</span>
              <span class="bat-card-lang">json</span>
            </div>

            <div class="bat-card-body bat-card-body-stack">
              <div class="bat-line">
                <span class="bat-gutter">1</span>
                <div class="bat-code">
                  <dl class="bat-definition-list">
                    <div>
                      <dt>{overview.copy.metadataStatusLabel}</dt>
                      <dd>{topic.status}</dd>
                    </div>
                    <div>
                      <dt>{overview.copy.metadataOwnerLabel}</dt>
                      <dd>{topic.owner}</dd>
                    </div>
                    <div>
                      <dt>{overview.copy.metadataOutcomeLabel}</dt>
                      <dd>{topic.outcome}</dd>
                    </div>
                  </dl>
                </div>
              </div>
            </div>
          </article>
        </section>

        <section class="bat-grid bat-grid-detail">
          <article class="bat-card bat-card-wide">
            <div class="bat-card-bar">
              <span class="bat-card-file">{overview.copy.practicesFile}</span>
              <span class="bat-card-lang">text</span>
            </div>

            <div class="bat-card-body bat-card-body-stack">
              <div class="bat-line">
                <span class="bat-gutter">1</span>
                <div class="bat-code">
                  <p class="bat-heading bat-heading-inline">{overview.copy.practicesHeading}</p>
                  <ul class="bat-list-block">
                    {topic.practices.map((practice) => <li>{practice}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        </section>

        <section class="bat-grid bat-grid-detail">
          <article class="bat-card">
            <div class="bat-card-bar">
              <span class="bat-card-file">{overview.copy.metricsFile}</span>
              <span class="bat-card-lang">csv</span>
            </div>

            <div class="bat-card-body bat-card-body-stack">
              <div class="bat-line">
                <span class="bat-gutter">1</span>
                <div class="bat-code">
                  <p class="bat-heading bat-heading-inline">{overview.copy.metricsHeading}</p>
                  <ul class="bat-list-block">
                    {topic.metrics.map((metric) => <li>{metric}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        </section>

        {topic.measurementLayers.length > 0 ? (
          <>
            <section class="standard-section-heading" id="measurement-layers">
              <div>
                <p class="eyebrow">Measurement Layers</p>
                <h2>Metrics that can actually be operated</h2>
              </div>
              <p class="standard-section-meta">{topic.measurementLayers.length} layers</p>
            </section>

            <section class="bat-grid bat-grid-detail">
              {topic.measurementLayers.map((layer, index) => (
                <article class="bat-card">
                  <div class="bat-card-bar">
                    <span class="bat-card-file">measurement-layer-{index + 1}.md</span>
                    <span class="bat-card-lang">md</span>
                  </div>

                  <div class="bat-card-body bat-card-body-stack">
                    <div class="bat-line">
                      <span class="bat-gutter">1</span>
                      <div class="bat-code">
                        <p class="bat-heading">{layer.title}</p>
                        <p class="bat-copy">{layer.summary}</p>
                      </div>
                    </div>
                    <div class="bat-line">
                      <span class="bat-gutter">2</span>
                      <div class="bat-code">
                        <ul class="bat-list-block">
                          {layer.signals.map((signal) => <li>{signal}</li>)}
                        </ul>
                      </div>
                    </div>
                    <div class="bat-line">
                      <span class="bat-gutter">3</span>
                      <div class="bat-code">
                        <p class="bat-heading bat-heading-inline">Recommended chart</p>
                        <p class="bat-copy">{layer.chart}</p>
                        <p class="bat-heading bat-heading-inline">Source hint</p>
                        <p class="bat-copy">{layer.sourceHint}</p>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </section>
          </>
        ) : null}

        {topic.dataSources.length > 0 ? (
          <>
            <section class="standard-section-heading" id="organization-sources">
              <div>
                <p class="eyebrow">Organization Sources</p>
