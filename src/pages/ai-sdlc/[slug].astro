{topic.slug === "skills" ? (
  <script is:inline>
    const skillsList = document.querySelector("#skills-list");
    const skillEntries = skillsList ? [...skillsList.querySelectorAll(".skills-entry")] : [];
    const skillsSearch = document.querySelector("#skills-search");
    const skillsEvaluatedOnly = document.querySelector("#skills-evaluated-only");
    const skillsResultsCount = document.querySelector("#skills-results-count");
    const skillsEmptyState = document.querySelector("#skills-empty-state");

    const normalize = (value) => value.trim().toLowerCase();
    const highlightTargets = skillEntries.flatMap((entry) => [...entry.querySelectorAll("[data-highlight-text]")]);

    const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    const renderHighlightedText = (element, query) => {
      const originalText = element.dataset.originalText ?? element.textContent ?? "";
      element.dataset.originalText = originalText;

      if (!query) {
        element.textContent = originalText;
        return;
      }

      const matcher = new RegExp(`(${escapeRegExp(query)})`, "ig");
      const fragments = originalText.split(matcher);

      element.replaceChildren(
        ...fragments
          .filter((fragment) => fragment.length > 0)
          .map((fragment) => {
            if (fragment.toLowerCase() === query) {
              const mark = document.createElement("mark");
              mark.className = "skills-search-highlight";
              mark.textContent = fragment;
              return mark;
            }

            return document.createTextNode(fragment);
          })
      );
    };

    const getFilters = () => ({
      search: skillsSearch instanceof HTMLInputElement ? normalize(skillsSearch.value) : "",
      evaluatedOnly: skillsEvaluatedOnly instanceof HTMLInputElement ? skillsEvaluatedOnly.checked : false,
    });

    const updateSkillResults = () => {
      const filters = getFilters();
      let visibleCount = 0;

      skillEntries.forEach((entry) => {
        const matchesSearch = !filters.search || entry.dataset.search?.includes(filters.search);
        const matchesEvaluated = !filters.evaluatedOnly || entry.dataset.evaluated === "true";
        const shouldShow = Boolean(matchesSearch && matchesEvaluated);

        entry.toggleAttribute("hidden", !shouldShow);

        if (shouldShow) {
          visibleCount += 1;
        }
      });

      if (skillsResultsCount) {
        const suffix = skillsResultsCount.dataset.resultsCountSuffix || "skills visible";
        skillsResultsCount.textContent = `${visibleCount} ${suffix}`;
      }

      if (skillsEmptyState instanceof HTMLElement) {
        skillsEmptyState.hidden = visibleCount > 0;
      }

      highlightTargets.forEach((element) => {
        renderHighlightedText(element, filters.search);
      });
    };

    [skillsSearch, skillsEvaluatedOnly].forEach((control) => {
      control?.addEventListener("input", updateSkillResults);
      control?.addEventListener("change", updateSkillResults);
    });

    updateSkillResults();
  </script>
) : topic.slug === "harness-tools" ? (
  <script type="module" is:inline>
