          const sortedModelOrder = sortByTotalDescending(modelOrder, modelTotalsForSorting);
  
          const series = teams.map((team: AiMetricsTeam) => ({
          name: team.name,
          type: "bar",
          stack: "model-users",
          barMaxWidth: 28,
          barCategoryGap: "20%",
          itemStyle: {
            color: team.color,
            borderRadius: [0, 0, 0, 0],
          },
          emphasis: {
            focus: "series",
          },
          data: sortedModelOrder.map((model) => {
            const usage = team.modelUsage.find((entry: AiMetricsModelUsage) => entry.model === model);
            const rawUsers = usage?.users ?? 0;
            const rawSessions = usage?.monthlySessions ?? 0;
            const rawTokens = usage?.monthlyTokens ?? 0;
            const modelTotals = totalsByModel.get(model) ?? { users: 0, tokens: 0 };

            return {
              value: valueMode === "ratio" ? (modelTotals.users > 0 ? rawUsers / modelTotals.users : 0) : rawUsers,
              rawUsers,
              rawSessions,
              rawTokens,
              modelTotal: modelTotals.users,
              totalTokens: modelTotals.tokens,
            };
          }),
        }));

        modelChartInstance.setOption(
          {
            animationDuration: 250,
            animationDurationUpdate: 250,
            color: teams.map((team: AiMetricsTeam) => team.color),
            grid: {
              left: 156,
              right: 32,
              top: 72,
              bottom: 14,
            },
            legend: {
              type: "scroll",
              top: 12,
              left: 12,
              right: 12,
              itemWidth: 12,
              itemHeight: 12,
              textStyle: {
                color: "#162028",
                fontFamily: "Cascadia Code, Fira Code, monospace",
                fontSize: 12,
                fontWeight: 700,
              },
            },
            tooltip: {
              trigger: "axis",
              axisPointer: {
                type: "shadow",
              },
              backgroundColor: "rgba(255, 255, 255, 0.96)",
              borderColor: "rgba(22, 32, 40, 0.12)",
              borderWidth: 1,
              textStyle: {
                color: "#162028",
                fontFamily: "Cascadia Code, Fira Code, monospace",
              },
              formatter: (paramsList: unknown) => {
                const points = (Array.isArray(paramsList) ? paramsList : [paramsList]) as MetricsModelPoint[];
                const model = points[0]?.axisValueLabel ?? "";
                const totalUsers = points[0]?.data?.modelTotal ?? 0;
                const totalTokens = points[0]?.data?.totalTokens ?? 0;
                const rows = points
                  .filter((point) => (point.data?.rawUsers ?? 0) > 0)
                  .map((point) => {
                    const ratio = totalUsers > 0 ? point.data.rawUsers / totalUsers : 0;
                    const valueLabel =
                      valueMode === "ratio"
                        ? `${formatPercent(point.data.value)} of ${model}`
                        : `${formatInt(point.data.rawUsers)} users`;

                    return `${point.marker} ${point.seriesName}: ${valueLabel} (${formatPercent(ratio)}) • ${formatInt(point.data.rawSessions)} sessions • ${formatCompactInt(point.data.rawTokens)} tokens`;
                  });

                return [
                  `<strong>${model}</strong>`,
                  `Total users: ${formatInt(totalUsers)}`,
                  `Total tokens: ${formatCompactInt(totalTokens)}`,
                  ...rows,
                ].join("<br/>");
              },
            },
            xAxis: {
              type: "value",
              max: valueMode === "ratio" ? 1 : undefined,
              axisLabel: {
                color: "#57636e",
                formatter: (value: number) => (valueMode === "ratio" ? formatPercent(value) : formatInt(value)),
              },
              splitLine: {
                lineStyle: {
                  color: "rgba(87, 99, 110, 0.16)",
                },
              },
            },
            yAxis: {
              type: "category",
                data: sortedModelOrder,
              axisTick: {
                show: false,
              },
              axisLabel: {
                color: "#162028",
                fontFamily: "Cascadia Code, Fira Code, monospace",
                fontSize: 12,
                fontWeight: 700,
              },
            },
            series,
          },
          true
        );
      };

        const renderAll = () => {
      const teams = getVisibleTeams();
      if (startDateInput instanceof HTMLInputElement) {
        startDateInput.value = startDate;
        startDateInput.max = endDate;
      }

      if (endDateInput instanceof HTMLInputElement) {
        endDateInput.value = endDate;
        endDateInput.min = startDate;
        endDateInput.max = defaultEndDate;
      }

        syncButtons();
        syncTeamFilterUi();
        syncQueryParams();
          renderPlatformChart(teams);
          renderRepositoryChart(teams);
          renderModelChart(teams);
          renderSummary(teams);
        };

    if (teamTrigger instanceof HTMLButtonElement) {
      teamTrigger.addEventListener("click", () => {
        const isOpen = teamTrigger.getAttribute("aria-expanded") === "true";
        setTeamPanelOpen(!isOpen);
      });
    }

    if (teamResetButton instanceof HTMLButtonElement) {
      teamResetButton.addEventListener("click", () => {
        selectedTeams.clear();
        renderAll();
        setTeamPanelOpen(false);
      });
    }

    teamCheckboxes.forEach((checkbox) => {
      if (!(checkbox instanceof HTMLInputElement)) {
        return;
      }

      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          selectedTeams.add(checkbox.value);
        } else {
          selectedTeams.delete(checkbox.value);
        }

        renderAll();
      });
    });

    if (teamSearchInput instanceof HTMLInputElement) {
      teamSearchInput.addEventListener("input", () => {
        teamSearch = teamSearchInput.value.trim().toLowerCase();
        syncTeamFilterUi();
      });
    }

    valueModeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        valueMode = button.getAttribute("data-value-mode") === "ratio" ? "ratio" : "total";
        renderAll();
      });
    });

    if (startDateInput instanceof HTMLInputElement) {
      startDateInput.addEventListener("change", () => {
        if (!isIsoDate(startDateInput.value)) {
          startDateInput.value = startDate;
          return;
        }

        startDate = startDateInput.value;

        if (startDate > endDate) {
          endDate = startDate;
        }

        renderAll();
      });
    }

    if (endDateInput instanceof HTMLInputElement) {
      endDateInput.addEventListener("change", () => {
        if (!isIsoDate(endDateInput.value)) {
          endDateInput.value = endDate;
          return;
        }

        endDate = endDateInput.value > defaultEndDate ? defaultEndDate : endDateInput.value;

        if (endDate < startDate) {
          startDate = endDate;
        }

        renderAll();
      });
      }

      window.addEventListener("resize", () => {
        platformChartInstance?.resize();
        repositoryChartInstance?.resize();
        modelChartInstance?.resize();
      });
      document.addEventListener("pointerdown", (event) => {
        if (!(teamFilter instanceof HTMLElement) || !(event.target instanceof Node)) {
          return;
        }

        if (!teamFilter.contains(event.target)) {
          setTeamPanelOpen(false);
      }
    }, true);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setTeamPanelOpen(false);
      }
    });

    renderAll();
</script>

<script>
  import { initFloatingRail } from "../../scripts/floating-rail.ts";

  initFloatingRail({
    rail: "#metrics-team-rail",
    anchor: "#metrics-team-rail-anchor",
    dock: "#metrics-team-rail-dock",
  });
</script>
) : null}
