      `${value.getFullYear()}-${`${value.getMonth() + 1}`.padStart(2, "0")}-${`${value.getDate()}`.padStart(2, "0")}`;
    const parseIsoDate = (value: string) => {
      const [year, month, day] = value.split("-").map((segment: string) => Number.parseInt(segment, 10));
