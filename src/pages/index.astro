---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main class="hero">
    <p class="eyebrow">Astro 6.1 + GitHub Pages</p>
    <h1>Base lista para empezar.</h1>
    <p class="copy">
      Este proyecto genera HTML estatico en <code>dist/</code> y se publica con
      GitHub Actions en GitHub Pages.
    </p>

    <div class="actions">
      <a href="https://docs.astro.build" target="_blank" rel="noreferrer">
        Astro Docs
      </a>
      <a href="https://docs.github.com/pages" target="_blank" rel="noreferrer">
        GitHub Pages
      </a>
    </div>
  </main>
</BaseLayout>
