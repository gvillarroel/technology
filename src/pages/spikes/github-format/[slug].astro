---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SpikePageFrame from "../../../components/SpikePageFrame.astro";
import { getCollection, render } from "astro:content";
import { getScopedHtmlPageUrl, getScopedMarkdownPageUrl } from "../../../lib/dual-format";
import { getSpikePageContent, getSpikeSectionNavItems } from "../../../lib/spikes";

export async function getStaticPaths() {
  const pages = await getCollection("github-format-pages");

  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: any };
const { Content } = await render(page);
const htmlUrl = getScopedHtmlPageUrl("/spikes/github-format", page.data.slug);
const markdownUrl = getScopedMarkdownPageUrl("/spikes/github-format", page.data.slug);
const spikePage = await getSpikePageContent("github-format");
const spikeSectionNavItems = await getSpikeSectionNavItems("github-format");
---

<BaseLayout title={`${page.data.title} | GitHub Format Spike`} description={page.data.description}>
  <main>
    <SpikePageFrame
      eyebrow={spikePage.eyebrow}
      title={page.data.title}
      summary={page.data.description ?? spikePage.summary}
      pills={spikePage.pills}
      searchAction={spikePage.href}
      searchPlaceholder="Search spike pages"
      sectionNavItems={spikeSectionNavItems}
      sectionTrailItems={[
        { href: spikePage.href, label: spikePage.label, current: false },
        { label: page.data.title, current: true },
      ]}
    >
    <section class="section-block prose-block">
      <p class="copy standard-copy-wide">
        Route pair:
        <a href={htmlUrl}>Open HTML page</a>
        and
        <a href={markdownUrl}>Open Markdown page</a>.
      </p>
    </section>

    <article class="section-block prose-block">
      <Content />
    </article>
    </SpikePageFrame>
  </main>
</BaseLayout>
