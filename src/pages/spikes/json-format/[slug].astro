---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SpikePageFrame from "../../../components/SpikePageFrame.astro";
import { getCollection, render } from "astro:content";
import { getScopedHtmlPageUrl, getScopedMarkdownPageUrl } from "../../../lib/dual-format";
import { getSpikePageContent, getSpikeSectionNavItems } from "../../../lib/spikes";

export async function getStaticPaths() {
  const pages = await getCollection("json-format-pages");

  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: any };
const { Content } = await render(page);
const htmlUrl = getScopedHtmlPageUrl("/spikes/json-format", page.data.slug);
const markdownUrl = getScopedMarkdownPageUrl("/spikes/json-format", page.data.slug);
const spikePage = await getSpikePageContent("json-format");
const spikeSectionNavItems = await getSpikeSectionNavItems("json-format");
---

<BaseLayout title={`${page.data.title} | JSON Format Spike`} description={page.data.description}>
  <main>
    <SpikePageFrame
      eyebrow={spikePage.eyebrow}
      title={page.data.title}
      summary={page.data.description ?? spikePage.summary}
      pills={spikePage.pills}
      sectionNavItems={spikeSectionNavItems}
      sectionTrailItems={[
        { href: spikePage.href, label: spikePage.label, current: false },
        { label: page.data.title, current: true },
      ]}
    >
    <section class="section-block prose-block">
      <p class="copy standard-copy-wide">
        HTML URL: <a href={htmlUrl}>{htmlUrl}</a><br />
        Markdown URL: <a href={markdownUrl}>{markdownUrl}</a>
      </p>
    </section>

    <article class="section-block prose-block">
      <Content />
    </article>
    </SpikePageFrame>
  </main>
</BaseLayout>
