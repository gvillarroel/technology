---
import BaseLayout from "../layouts/BaseLayout.astro";
import StandardPageHeader from "../components/StandardPageHeader.astro";
import StandardPageIntro from "../components/StandardPageIntro.astro";
import StandardSourceCard from "../components/StandardSourceCard.astro";
import { getAiSdlcData, getAiSdlcDetailHtmlUrl } from "../lib/ai-sdlc";
import { getStandardPageSource } from "../lib/page-sources";

const { overview, topics } = await getAiSdlcData();
const sourceCard = await getStandardPageSource("ai-sdlc");
const visibleTopics = topics;
const aiSdlcSectionNavItems = [
  {
    href: "/ai-sdlc/",
    label: "Overview",
    current: true,
  },
  ...topics.map((topic) => ({
    href: getAiSdlcDetailHtmlUrl(topic.slug),
    label: topic.name,
    current: false,
  })),
];
---

<BaseLayout
  title={`${overview.title} | e*f(x) Technology`}
  description={overview.summary}
>
  <main class="shell shell-narrow standard-page">
    <StandardPageHeader
      currentPage="ai-sdlc"
      searchAction="/ai-sdlc/"
      searchPlaceholder={overview.copy.searchPlaceholder}
      searchQuery=""
      sectionNavItems={aiSdlcSectionNavItems}
      sectionNavLabel="AI SDLC sections"
    />

    <StandardPageIntro
      eyebrow={overview.copy.indexEyebrow}
      title={overview.copy.indexHeading}
      summary={overview.copy.indexIntro}
      pills={[
        { label: "Topics", value: String(visibleTopics.length) },
        { label: "Owner", value: overview.owner },
        { label: "Updated", value: overview.updated },
      ]}
    />

    <section class="bat-grid bat-grid-radar">
      <StandardSourceCard
        file={sourceCard.file}
        lang={sourceCard.lang}
        title={sourceCard.title}
        summary={sourceCard.summary}
        meta={[
          { label: overview.copy.sourceOwnerLabel, value: overview.owner },
          { label: overview.copy.sourceUpdatedLabel, value: overview.updated },
          { label: overview.copy.sourceTopicsLabel, value: String(visibleTopics.length) },
        ]}
      />
    </section>

    <section class="standard-section-heading">
      <div>
        <p class="eyebrow">{overview.copy.topicsEyebrow}</p>
        <h2>{overview.copy.topicsHeading}</h2>
      </div>
      <p class="standard-section-meta" id="ai-sdlc-topics-count">{visibleTopics.length} {overview.copy.topicsCountSuffix}</p>
    </section>

    <section class="ai-sdlc-grid">
      {visibleTopics.map((topic, index) => (
        <article
          class="ai-sdlc-card"
          data-ai-sdlc-card
          data-search-text={[topic.name, topic.slug, topic.summary, topic.status, topic.owner, topic.outcome].join(" ").toLowerCase()}
        >
          <div class="ai-sdlc-card-topline">
            <a class="ai-sdlc-card-file-link" href={getAiSdlcDetailHtmlUrl(topic.slug)}>
              <span class="ai-sdlc-card-file">{topic.slug}.md</span>
              <span class="ai-sdlc-card-link-arrow" aria-hidden="true">↗</span>
            </a>
            <span class="community-card-index">{String(index + 1).padStart(2, "0")}</span>
          </div>

          <div class="ai-sdlc-card-body">
            <p class="ai-sdlc-card-copy">{topic.summary}</p>
          </div>
        </article>
      ))}
    </section>

    <p class="standard-empty-state" id="ai-sdlc-empty-state" hidden>No AI SDLC topics match the current search.</p>
  </main>
</BaseLayout>

<script is:inline>
  const searchInput = document.getElementById("site-search");
  const topicCards = Array.from(document.querySelectorAll("[data-ai-sdlc-card]"));
  const topicsCount = document.getElementById("ai-sdlc-topics-count");
  const emptyState = document.getElementById("ai-sdlc-empty-state");
  const countSuffix = "topics";

  const normalizeText = (value) => String(value ?? "").trim().toLowerCase().replace(/\s+/g, " ");

  const applyFilter = () => {
    const params = new URLSearchParams(window.location.search);
    const query = normalizeText(params.get("q") ?? "");

    if (searchInput instanceof HTMLInputElement) {
      searchInput.value = params.get("q") ?? "";
    }

    let visibleCount = 0;

    topicCards.forEach((card) => {
      if (!(card instanceof HTMLElement)) {
        return;
      }

      const haystack = normalizeText(card.dataset.searchText ?? "");
      const matches = !query || haystack.includes(query);
      card.hidden = !matches;
      if (matches) {
        visibleCount += 1;
      }
    });

    if (topicsCount instanceof HTMLElement) {
      topicsCount.textContent = `${visibleCount} ${countSuffix}`;
    }

    if (emptyState instanceof HTMLElement) {
      emptyState.hidden = visibleCount > 0 || !query;
    }
  };

  applyFilter();
</script>
