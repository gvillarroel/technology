---
import BaseLayout from "../layouts/BaseLayout.astro";
import StandardPageHeader from "../components/StandardPageHeader.astro";
import { getTechCommunities } from "../lib/tech-communities";

const communities = await getTechCommunities();
const tracks = ["Software", "AI", "Products"];
---

<BaseLayout
  title="Tech Communities | Berkeley Facts"
  description="Directory of Berkeley Facts technology communities across AI, InnerSource, product, data, and related practices."
>
  <main class="shell shell-narrow standard-page">
    <StandardPageHeader
      currentPage="communities"
      searchAction="/communities/"
      searchPlaceholder="Search communities or audience"
    />

    <section class="standard-page-intro">
      <div>
        <p class="eyebrow">Berkeley Facts</p>
        <h1 class="standard-page-title">Technology communities for shared practice.</h1>
        <p class="copy standard-copy-wide">
          This page lists Berkeley Facts communities for artificial intelligence, InnerSource,
          product, and adjacent technology practices. Read the summary first, filter by category,
          then open the external community link that best matches the work you are doing.
        </p>
      </div>
    </section>

    <section class="standard-toggle-row" aria-label="Technology community track filters">
      <p class="standard-label standard-label-inline">Track</p>
      <div class="standard-toggle-group" id="community-track-filter">
        <button class="standard-toggle-button is-active" type="button" data-track-filter="">
          All
        </button>
        {tracks.map((track) => (
          <button class="standard-toggle-button" type="button" data-track-filter={track}>
            {track}
          </button>
        ))}
      </div>
    </section>

    <section class="standard-section-heading">
      <div>
        <p class="eyebrow">Directory</p>
        <h2>Community index</h2>
      </div>
      <p class="standard-section-meta" id="communities-results-count">
        {communities.length} communities visible
      </p>
    </section>

    <section class="community-grid" id="communities-list">
      {communities.map((community, index) => (
        <article
          class="community-card"
          data-name={community.name}
          data-track={community.track}
          data-category={community.category}
          data-search={`${community.name} ${community.track} ${community.category} ${community.tags.join(" ")} ${community.summary} ${community.audience.join(" ")}`.toLowerCase()}
        >
          <div class="community-card-topline">
            <span class="community-card-category">{community.category}</span>
            <span class="community-card-index">{String(index + 1).padStart(2, "0")}</span>
          </div>
          <div class="community-card-body">
            <h3 class="community-card-title">{community.name}</h3>
            <p class="community-card-copy">{community.summary}</p>
            <div class="community-card-meta">
              <span>cadence: {community.cadence}</span>
              <span>audience: {community.audience.join(", ")}</span>
            </div>
            <div class="community-card-tags" aria-label="Community tags">
              {community.tags.map((tag) => (
                <span class={`community-tag-pill community-tag-pill-${community.track.toLowerCase()}`}>{tag}</span>
              ))}
            </div>
            <a class="community-card-link" href={community.link} target="_blank" rel="noreferrer">
              {community.linkLabel}
            </a>
          </div>
        </article>
      ))}
    </section>

    <p class="standard-empty-state" id="communities-empty-state" hidden>
      No communities match the current filters.
    </p>
  </main>
</BaseLayout>

<script is:inline>
  const initCommunitiesPage = () => {
    const searchInput = document.querySelector("#site-search");
    const trackFilter = document.querySelector("#community-track-filter");
    const trackButtons = trackFilter ? [...trackFilter.querySelectorAll("[data-track-filter]")] : [];
    const list = document.querySelector("#communities-list");
    const entries = list ? [...list.querySelectorAll(".community-card")] : [];
    const countLabel = document.querySelector("#communities-results-count");
    const emptyState = document.querySelector("#communities-empty-state");
    const params = new URLSearchParams(window.location.search);

    if (!trackFilter || !entries.length) {
      return;
    }

    const normalize = (value) => value.trim().toLowerCase();

    const getActiveTrack = () =>
      trackButtons.find((button) => button.classList.contains("is-active"))?.getAttribute("data-track-filter") ?? "";

    const getFilters = () => ({
      search: searchInput instanceof HTMLInputElement ? normalize(searchInput.value) : "",
      track: getActiveTrack(),
    });

    const syncQueryParams = () => {
      const nextParams = new URLSearchParams(window.location.search);
      const controlValues = [
        ["q", searchInput instanceof HTMLInputElement ? searchInput.value.trim() : ""],
        ["track", getActiveTrack()],
      ];

      controlValues.forEach(([key, value]) => {
        if (value) {
          nextParams.set(key, value);
        } else {
          nextParams.delete(key);
        }
      });

      const nextUrl = nextParams.toString() ? `?${nextParams.toString()}` : window.location.pathname;
      window.history.replaceState({}, "", nextUrl);
    };

    const updateResults = () => {
      const filters = getFilters();
      const visibleEntries = [];

      entries.forEach((entry) => {
        const search = entry.getAttribute("data-search") ?? "";
        const matchesSearch = !filters.search || search.includes(filters.search);
        const matchesTrack = !filters.track || entry.getAttribute("data-track") === filters.track;
        const shouldShow = matchesSearch && matchesTrack;

        if (shouldShow) {
          if (entry instanceof HTMLElement) {
            entry.style.display = "";
          }
          entry.removeAttribute("hidden");
          visibleEntries.push(entry);
        } else {
          if (entry instanceof HTMLElement) {
            entry.style.display = "none";
          }
          entry.setAttribute("hidden", "");
        }
      });

      if (countLabel) {
        countLabel.textContent = `${visibleEntries.length} communities visible`;
      }

      if (emptyState instanceof HTMLElement) {
        emptyState.hidden = visibleEntries.length > 0;
      }

      syncQueryParams();
    };

    if (searchInput instanceof HTMLInputElement && params.has("q")) {
      searchInput.value = params.get("q") ?? "";
    }

    if (params.has("track")) {
      const current = params.get("track") ?? "";
      trackButtons.forEach((button) => {
        button.classList.toggle("is-active", button.getAttribute("data-track-filter") === current);
      });
    }

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", updateResults);
      searchInput.addEventListener("change", updateResults);
    }

    trackFilter.addEventListener("click", (event) => {
      const button = event.target instanceof HTMLElement
        ? event.target.closest("[data-track-filter]")
        : null;

      if (!(button instanceof HTMLElement)) {
        return;
      }

      trackButtons.forEach((candidate) => {
        candidate.classList.toggle("is-active", candidate === button);
      });

      updateResults();
    });

    updateResults();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCommunitiesPage, { once: true });
  } else {
    initCommunitiesPage();
  }
</script>
