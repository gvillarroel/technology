---
import BaseLayout from "../layouts/BaseLayout.astro";
import StandardPageHeader from "../components/StandardPageHeader.astro";
import { getDocumentIndexData } from "../lib/documents";
import { withBasePath } from "../lib/site-url";

const searchQuery = "";
const { repositorySummaries, sourceConfigs, scannedRepositories, documentCount, searchEntries } = await getDocumentIndexData();
const latestRepositoryUpdate =
  [...repositorySummaries]
    .map((entry) => entry.updated)
    .filter(Boolean)
    .sort()
    .at(-1) ?? "";
const formatDisplayDate = (value?: string) => {
  if (!value) {
    return "Timestamp unavailable";
  }

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);
};
const formatRepositoryUpdatedLabel = (value?: string) =>
  value ? formatDisplayDate(value) : "timestamp unavailable";
const configFilesPreview = [
  "data/document-repositories.yaml",
  "src/lib/documents.ts",
  "src/pages/documents.astro",
  "src/pages/documents/[...slug].astro",
].join("\n");
const getEntryTimestamp = (value?: string) => {
  if (!value) {
    return 0;
  }

  const timestamp = Date.parse(value);
  return Number.isNaN(timestamp) ? 0 : timestamp;
};
const comparePageEntries = (
  left: (typeof searchEntries)[number],
  right: (typeof searchEntries)[number],
) => {
  const timestampDifference = getEntryTimestamp(right.updated) - getEntryTimestamp(left.updated);

  if (timestampDifference !== 0) {
    return timestampDifference;
  }

  if (left.status !== right.status) {
    return left.status === "Generated" ? 1 : -1;
  }

  if (left.isFolderIndex !== right.isFolderIndex) {
    return left.isFolderIndex ? -1 : 1;
  }

  return (
    left.repository.localeCompare(right.repository) ||
    left.title.localeCompare(right.title) ||
    left.relativePath.localeCompare(right.relativePath)
  );
};
const documentEntries = searchEntries
  .filter((entry) => entry.pageType === "document")
  .sort(comparePageEntries);
const recentlyUpdatedEntries = [...searchEntries]
  .filter((entry) => entry.updated)
  .sort((left, right) => right.updated.localeCompare(left.updated))
  .slice(0, 6);
---

<BaseLayout
  title="Documentation | e*f(x) Technology"
  description="Governed Markdown document library for internal manuals, protocols, and operational references."
>
  <main class="shell shell-narrow standard-page">
    <StandardPageHeader
      currentPage="documents"
      searchAction={withBasePath("/documents/")}
      searchPlaceholder="Search repositories or document paths"
      searchQuery={searchQuery}
    />

    <section class="standard-page-intro docs-index-hero">
      <div class="docs-index-hero-copy">
        <p class="eyebrow">Documentation</p>
        <h1 class="standard-page-title">Repository-driven documentation.</h1>
        <p class="copy standard-copy-wide">
          Browse repository docs as a single library, with one page per repository and folder-aware
          navigation for every Markdown section that was discovered during the build.
        </p>
      </div>
      <div class="docs-index-hero-trust" aria-label="Documentation library summary">
        <span>{repositorySummaries.length} repositories</span>
        <span>{documentCount} pages</span>
        <span>last update: {formatDisplayDate(latestRepositoryUpdate)}</span>
      </div>
    </section>

    <section class="docs-index-strip" aria-label="Library scan summary">
      <article class="docs-index-metric-card">
        <p class="docs-index-metric-label">Library coverage</p>
        <p class="docs-index-metric-value">{repositorySummaries.length} repositories with docs</p>
        <p class="docs-index-metric-copy">
          From {scannedRepositories.length} scanned repositories under the configured GitHub account.
        </p>
      </article>

      <article class="docs-index-metric-card">
        <p class="docs-index-metric-label">Freshness signal</p>
        <p class="docs-index-metric-value">{documentCount} Markdown pages indexed</p>
        <p class="docs-index-metric-copy">
          Latest dated update found in the library: {formatDisplayDate(latestRepositoryUpdate)}.
        </p>
      </article>

      <article class="docs-index-metric-card is-compact">
        <p class="docs-index-metric-label">Configuration</p>
        <p class="docs-index-metric-value">{sourceConfigs.length} scan rule set</p>
        <pre class="adrs-yaml-preview docs-index-config-preview"><code>{configFilesPreview}</code></pre>
      </article>
    </section>

    {recentlyUpdatedEntries.length > 0 ? (
      <section class="docs-recent-section docs-recent-section-compact">
        <div class="standard-section-heading">
          <div>
            <p class="eyebrow">Freshness</p>
            <h2>Recently updated documents</h2>
          </div>
          <p class="standard-section-meta">Latest verified timestamps in the scanned library</p>
        </div>

        <div class="docs-recent-grid docs-recent-grid-compact">
          {recentlyUpdatedEntries.slice(0, 3).map((entry) => (
            <a class="docs-recent-card" href={entry.htmlUrl}>
              <div class="docs-recent-card-topline">
                <span class="docs-recent-card-repository">{entry.repository}</span>
                <span class="docs-recent-card-date">{formatDisplayDate(entry.updated)}</span>
              </div>
              <h3 class="docs-recent-card-title">{entry.title}</h3>
              <p class="docs-recent-card-path">{entry.relativePath}</p>
              <p class="docs-recent-card-copy">{entry.summary}</p>
            </a>
          ))}
        </div>
      </section>
    ) : null}

    <section class="docs-search-results" id="docs-search-results" hidden>
      <div class="standard-section-heading">
        <div>
          <p class="eyebrow">Search</p>
          <h2 id="docs-search-results-title">Results</h2>
        </div>
        <p class="standard-section-meta" id="docs-search-results-meta">0 pages matched</p>
      </div>

      <div class="docs-search-results-list" id="docs-search-results-list"></div>
      <p class="standard-empty-state" id="docs-search-results-empty" hidden>
        No repository pages or document headings matched that query.
      </p>
    </section>

    <section class="standard-section-heading">
      <div>
        <p class="eyebrow">Library</p>
        <h2>Browse the scanned documentation library</h2>
      </div>
      <div class="docs-index-toolbar">
        <p class="standard-section-meta" id="docs-visible-meta">{repositorySummaries.length} repositories visible</p>
        <div class="docs-index-view-toggle" role="tablist" aria-label="Documentation view">
          <button type="button" class="docs-index-view-button is-active" data-docs-view="repositories" aria-pressed="true">
            Repositories
          </button>
          <button type="button" class="docs-index-view-button" data-docs-view="pages" aria-pressed="false">
            Pages
          </button>
        </div>
      </div>
    </section>

    <section class="docs-library-grid" id="docs-library-grid" data-docs-view-panel="repositories">
      {repositorySummaries.map((repository, index) => (
        <a
          class="docs-library-card docs-library-card-link"
          href={repository.htmlUrl}
          data-repository-search-text={[repository.repository, repository.summary, repository.owner, repository.roots.join(" ")].join(" ").toLowerCase()}
        >
          <div class="docs-library-topline">
            <span class="community-card-index">{String(index + 1).padStart(2, "0")}</span>
            <span class={`docs-status-pill docs-status-${repository.status.toLowerCase().replace(/\s+/g, "-")}`}>
              {repository.status}
            </span>
          </div>

          <div class="docs-library-body">
            <p class="docs-library-type">{repository.docType}</p>
            <h3 class="docs-library-title">{repository.repository}</h3>
            <p class="docs-library-copy">{repository.summary}</p>
            <div class="docs-library-meta">
              <span>owner: {repository.owner}</span>
              <span>updated: {formatRepositoryUpdatedLabel(repository.updated)}</span>
              <span>files: {repository.fileCount}</span>
              <span>folders: {repository.folderCount}</span>
              <span>rules: {repository.ruleCount}</span>
              <span>roots: {repository.roots.join(", ") || "None"}</span>
            </div>
            <span class="community-card-link">
              Open repository
            </span>
          </div>
        </a>
      ))}
    </section>

    <section class="docs-pages-grid" id="docs-pages-grid" data-docs-view-panel="pages" hidden>
      {documentEntries.map((entry) => (
        <a
          class="docs-page-card"
          href={entry.htmlUrl}
          data-page-search-text={[
            entry.repository,
            entry.title,
            entry.summary,
            entry.relativePath,
            ...entry.headings,
          ].join(" ").toLowerCase()}
          data-page-title={entry.title}
          data-page-summary={entry.summary}
          data-page-path={entry.relativePath}
          data-page-repository={entry.repository}
          data-page-updated={entry.updated}
          data-page-status={entry.status}
          data-page-folder-index={entry.isFolderIndex ? "true" : "false"}
        >
          <div class="docs-page-card-topline">
            <span class="docs-page-card-repository">{entry.repository}</span>
            <div class="docs-page-card-pills">
              <span class:list={["docs-origin-pill", entry.status === "Generated" ? "is-generated" : "is-curated"]}>
                {entry.status === "Generated" ? "Generated" : "Curated"}
              </span>
              <span class="docs-page-card-type">{entry.isFolderIndex ? "Section" : "Page"}</span>
            </div>
          </div>
          <h3 class="docs-page-card-title">{entry.title}</h3>
          <p class="docs-page-card-path">{entry.relativePath}</p>
          <p class="docs-page-card-copy">{entry.summary}</p>
          {entry.status === "Generated" ? (
            <p class="docs-page-card-note">
              Generated section overview because this folder did not expose a <code>README.md</code> or <code>index.md</code> page during the scan.
            </p>
          ) : null}
        </a>
      ))}
    </section>
  </main>

  <script id="docs-search-index" type="application/json" set:html={JSON.stringify(searchEntries)} />
</BaseLayout>

<script type="module">
  const searchIndexNode = document.getElementById("docs-search-index");
  const searchForm = document.querySelector('.standard-search');
  const searchInputs = Array.from(document.querySelectorAll('.standard-search input'));
  const resultsSection = document.getElementById("docs-search-results");
  const resultsList = document.getElementById("docs-search-results-list");
  const resultsTitle = document.getElementById("docs-search-results-title");
  const resultsMeta = document.getElementById("docs-search-results-meta");
  const resultsEmpty = document.getElementById("docs-search-results-empty");
  const visibleMeta = document.getElementById("docs-visible-meta");
  const repositoryCards = Array.from(document.querySelectorAll("[data-repository-search-text]"));
  const pageCards = Array.from(document.querySelectorAll("[data-page-search-text]"));
  const viewButtons = Array.from(document.querySelectorAll("[data-docs-view]"));
  const viewPanels = Array.from(document.querySelectorAll("[data-docs-view-panel]"));
  const recentSection = document.querySelector(".docs-recent-section");
  const searchEntries = searchIndexNode ? JSON.parse(searchIndexNode.textContent || "[]") : [];
  const pageCardsGrid = document.getElementById("docs-pages-grid");
  const pageCardMeta = pageCards.map((card) => ({
    card,
    href: card.getAttribute("href") || "",
    title: card.getAttribute("data-page-title") || "",
    summary: card.getAttribute("data-page-summary") || "",
    relativePath: card.getAttribute("data-page-path") || "",
    repository: card.getAttribute("data-page-repository") || "",
    updated: card.getAttribute("data-page-updated") || "",
    status: card.getAttribute("data-page-status") || "",
    isFolderIndex: card.getAttribute("data-page-folder-index") === "true",
  }));
  let activeView = "repositories";

  const escapeHtml = (value) =>
    value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  const highlight = (value, query) => {
    const safeValue = escapeHtml(value || "");

    if (!query) {
      return safeValue;
    }

    return safeValue.replace(
      new RegExp(`(${escapeRegExp(query)})`, "ig"),
      '<mark class="docs-search-highlight">$1</mark>',
    );
  };
  const getMatchingHeading = (headings, query) =>
    headings.find((heading) => heading.toLowerCase().includes(query.toLowerCase())) || "";
  const getTimestamp = (value) => {
    const timestamp = Date.parse(value || "");
    return Number.isNaN(timestamp) ? 0 : timestamp;
  };
  const compareDefaultPageOrder = (left, right) => {
    const timestampDifference = getTimestamp(right.updated) - getTimestamp(left.updated);

    if (timestampDifference !== 0) {
      return timestampDifference;
    }

    if (left.status !== right.status) {
      return left.status === "Generated" ? 1 : -1;
    }

    if (left.isFolderIndex !== right.isFolderIndex) {
      return left.isFolderIndex ? -1 : 1;
    }

    return (
      left.repository.localeCompare(right.repository) ||
      left.title.localeCompare(right.title) ||
      left.relativePath.localeCompare(right.relativePath)
    );
  };
  const getSearchScore = (entry, query) => {
    const normalizedQuery = query.trim().toLowerCase();

    if (!normalizedQuery) {
      return 0;
    }

    let score = 0;
    const title = entry.title.toLowerCase();
    const path = entry.relativePath.toLowerCase();
    const summary = (entry.summary || "").toLowerCase();
    const repository = entry.repository.toLowerCase();
    const headings = entry.headings.map((heading) => heading.toLowerCase());

    if (title === normalizedQuery) {
      score += 140;
    } else if (title.includes(normalizedQuery)) {
      score += 70;
    }

    if (headings.some((heading) => heading === normalizedQuery)) {
      score += 120;
    } else if (headings.some((heading) => heading.includes(normalizedQuery))) {
      score += 52;
    }

    if (path.includes(normalizedQuery)) {
      score += 46;
    }

    if (summary.includes(normalizedQuery)) {
      score += 24;
    }

    if (repository.includes(normalizedQuery)) {
      score += 12;
    }

    if (entry.status !== "Generated") {
      score += 6;
    }

    if (entry.isFolderIndex) {
      score += 4;
    }

    score += Math.min(getTimestamp(entry.updated) / 1000000000000, 10);

    return score;
  };
  const getMatchIndex = (value, query) => value.toLowerCase().indexOf(query.toLowerCase());
  const buildMatchSnippet = (value, query, radius = 72) => {
    const text = (value || "").replace(/\s+/g, " ").trim();

    if (!text) {
      return "";
    }

    const matchIndex = getMatchIndex(text, query);

    if (matchIndex === -1) {
      return highlight(text, query);
    }

    const start = Math.max(0, matchIndex - radius);
    const end = Math.min(text.length, matchIndex + query.length + radius);
    const prefix = start > 0 ? "…" : "";
    const suffix = end < text.length ? "…" : "";

    return `${prefix}${highlight(text.slice(start, end), query)}${suffix}`;
  };
  const getBestMatchSnippet = (entry, query) => {
    const matchingHeading = getMatchingHeading(entry.headings, query);

    if (matchingHeading) {
      return {
        label: "Heading",
        html: buildMatchSnippet(matchingHeading, query, 56),
      };
    }

    if (entry.summary && entry.summary.toLowerCase().includes(query.toLowerCase())) {
      return {
        label: "Summary",
        html: buildMatchSnippet(entry.summary, query),
      };
    }

    if (entry.relativePath && entry.relativePath.toLowerCase().includes(query.toLowerCase())) {
      return {
        label: "Path",
        html: buildMatchSnippet(entry.relativePath, query, 46),
      };
    }

    return {
      label: entry.status === "Generated" ? "Generated overview" : "Summary",
      html: highlight(entry.summary || entry.relativePath || entry.repository, query),
    };
  };
  const sortSearchResults = (entries, query) =>
    [...entries].sort((left, right) => {
      const scoreDifference = getSearchScore(right, query) - getSearchScore(left, query);

      if (scoreDifference !== 0) {
        return scoreDifference;
      }

      return compareDefaultPageOrder(left, right);
    });
  const reorderPageCards = (query) => {
    if (!pageCardsGrid) {
      return;
    }

    const normalizedQuery = query.trim().toLowerCase();
    const orderedCards = [...pageCardMeta].sort((left, right) => {
      if (normalizedQuery) {
        const leftEntry = {
          ...left,
          headings: [],
        };
        const rightEntry = {
          ...right,
          headings: [],
        };
        const scoreDifference = getSearchScore(rightEntry, normalizedQuery) - getSearchScore(leftEntry, normalizedQuery);

        if (scoreDifference !== 0) {
          return scoreDifference;
        }
      }

      return compareDefaultPageOrder(left, right);
    });

    for (const entry of orderedCards) {
      pageCardsGrid.append(entry.card);
    }
  };

  const updateUrl = (query, view) => {
    const url = new URL(window.location.href);

    if (query) {
      url.searchParams.set("q", query);
    } else {
      url.searchParams.delete("q");
    }

    if (view && view !== "repositories") {
      url.searchParams.set("view", view);
    } else {
      url.searchParams.delete("view");
    }

    window.history.replaceState({}, "", url);
  };

  const setView = (view) => {
    activeView = view === "pages" ? "pages" : "repositories";

    for (const button of viewButtons) {
      const isActive = button.getAttribute("data-docs-view") === activeView;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    }

    for (const panel of viewPanels) {
      panel.hidden = panel.getAttribute("data-docs-view-panel") !== activeView;
    }
  };

  const renderSearchResults = (query) => {
    const normalizedQuery = query.trim().toLowerCase();
    const matchingRepositories = repositoryCards.filter((card) =>
      (card.getAttribute("data-repository-search-text") || "").includes(normalizedQuery),
    );
    const matchingPages = pageCards.filter((card) =>
      (card.getAttribute("data-page-search-text") || "").includes(normalizedQuery),
    );

    for (const card of repositoryCards) {
      card.hidden = Boolean(normalizedQuery) && !matchingRepositories.includes(card);
    }

    for (const card of pageCards) {
      card.hidden = Boolean(normalizedQuery) && !matchingPages.includes(card);
    }

    reorderPageCards(normalizedQuery);

    visibleMeta.textContent =
      activeView === "pages"
        ? `${normalizedQuery ? matchingPages.length : pageCards.length} pages visible`
        : `${normalizedQuery ? matchingRepositories.length : repositoryCards.length} repositories visible`;

    if (recentSection) {
      recentSection.hidden = Boolean(normalizedQuery);
    }

    if (!normalizedQuery) {
      resultsSection.hidden = true;
      resultsList.innerHTML = "";
      resultsEmpty.hidden = true;
      return;
    }

    const results = sortSearchResults(
      searchEntries
      .filter((entry) =>
        [
          entry.repository,
          entry.title,
          entry.summary,
          entry.relativePath,
          ...entry.headings,
        ]
          .join(" ")
          .toLowerCase()
          .includes(normalizedQuery),
      ),
      normalizedQuery,
    )
      .slice(0, 24);

    resultsSection.hidden = false;
    resultsTitle.textContent = `Results for “${query}”`;
    resultsMeta.textContent = `${results.length} pages matched`;

    if (results.length === 0) {
      resultsList.innerHTML = "";
      resultsEmpty.hidden = false;
      return;
    }

    resultsEmpty.hidden = true;
    resultsList.innerHTML = results
      .map((entry) => {
        const snippet = getBestMatchSnippet(entry, query);
        const shouldRenderSummary =
          entry.summary &&
          snippet.label !== "Summary" &&
          entry.summary.trim().toLowerCase() !== (entry.relativePath || "").trim().toLowerCase();
        return `
          <a class="docs-search-result-card" href="${entry.htmlUrl}">
            <div class="docs-search-result-topline">
              <span class="docs-search-result-repository">${highlight(entry.repository, query)}</span>
              <span class="docs-search-result-type">${entry.status === "Generated" ? "Generated" : entry.isFolderIndex ? "Section" : "Page"}</span>
            </div>
            <h3 class="docs-search-result-title">${highlight(entry.title, query)}</h3>
            <p class="docs-search-result-path">${highlight(entry.relativePath || entry.repository, query)}</p>
            ${shouldRenderSummary ? `<p class="docs-search-result-copy">${escapeHtml(entry.summary)}</p>` : ""}
            <p class="docs-search-result-snippet"><span class="docs-search-result-snippet-label">${snippet.label}</span>${snippet.html}</p>
          </a>
        `;
      })
      .join("");
  };

  const initialQuery = new URL(window.location.href).searchParams.get("q") || "";
  const initialView = new URL(window.location.href).searchParams.get("view") || "repositories";

  for (const input of searchInputs) {
    input.value = initialQuery;
  }

  setView(initialView);
  renderSearchResults(initialQuery);
  updateUrl(initialQuery, activeView);

  for (const input of searchInputs) {
    input.addEventListener("input", (event) => {
      const query = event.currentTarget.value || "";

      for (const siblingInput of searchInputs) {
        if (siblingInput !== event.currentTarget) {
          siblingInput.value = query;
        }
      }

      renderSearchResults(query);
      updateUrl(query.trim(), activeView);
    });
  }

  for (const button of viewButtons) {
    button.addEventListener("click", () => {
      setView(button.getAttribute("data-docs-view") || "repositories");
      const query = searchInputs[0]?.value?.trim() || "";
      renderSearchResults(query);
      updateUrl(query, activeView);
    });
  }

  if (searchForm) {
    searchForm.addEventListener("submit", (event) => {
      event.preventDefault();
      const query = searchInputs[0]?.value?.trim() || "";
      renderSearchResults(query);
      updateUrl(query, activeView);
    });
  }
</script>
