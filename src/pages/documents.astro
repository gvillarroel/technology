---
import BaseLayout from "../layouts/BaseLayout.astro";
import StandardPageHeader from "../components/StandardPageHeader.astro";
import { getDocumentIndexData } from "../lib/documents";
import { withBasePath } from "../lib/site-url";

const { repositorySummaries, sourceConfigs, scannedRepositories, documentCount } = await getDocumentIndexData();
const configFilesPreview = [
  "data/",
  "  document-repositories.yaml",
  "src/lib/",
  "  documents.ts",
  "src/pages/",
  "  documents.astro",
  "  documents.md.ts",
  "  documents/[...slug].astro",
  "  documents/[...slug].md.ts",
].join("\n");
---

<BaseLayout
  title="Documentation | e*f(x) Technology"
  description="Governed Markdown document library for internal manuals, protocols, and operational references."
>
  <main class="shell shell-narrow standard-page">
    <StandardPageHeader
      currentPage="documents"
      searchAction={withBasePath("/documents/")}
      searchPlaceholder="Search repositories or document paths"
    />

    <section class="standard-page-intro">
      <div>
        <p class="eyebrow">Documentation</p>
        <h1 class="standard-page-title">Repository-driven documentation.</h1>
        <p class="copy standard-copy-wide">
          This section expands configured GitHub repository filters, scans Markdown files that match
          each repository's document rules, and turns every matching repository into a content page
          with a folder-aware navigation tree.
        </p>
      </div>
    </section>

    <section class="bat-grid bat-grid-detail">
      <article class="bat-card bat-card-wide">
        <div class="bat-card-bar">
          <span class="bat-card-file">GitHub repositories</span>
          <span class="bat-card-lang">scan</span>
        </div>

        <div class="bat-card-body bat-card-body-stack">
          <div class="bat-line">
            <span class="bat-gutter">1</span>
            <div class="bat-code">
              <p class="bat-heading">GitHub repository system</p>
              <p class="bat-copy">
                The Documentation section is driven from one central GitHub repository scan. During
                build, the site expands the configured account, inspects each repository tree
                offline, and promotes any matching `docs/**/*.md` files into static repository and
                document pages.
              </p>
            </div>
          </div>
          <div class="bat-line">
            <span class="bat-gutter">2</span>
            <div class="bat-code bat-meta-row">
              <span>config entries: {sourceConfigs.length}</span>
              <span>repositories scanned: {scannedRepositories.length}</span>
              <span>repositories with docs: {repositorySummaries.length}</span>
              <span>markdown files: {documentCount}</span>
            </div>
          </div>
        </div>
      </article>

      <article class="bat-card">
        <div class="bat-card-bar">
          <span class="bat-card-file">data/document-repositories.yaml</span>
          <span class="bat-card-lang">yaml</span>
        </div>

        <div class="bat-card-body bat-card-body-stack">
          <div class="bat-line">
            <span class="bat-gutter">1</span>
            <div class="bat-code">
              <p class="bat-heading">Configuration files</p>
              <p class="bat-copy">
                These are the only files you need to understand or change when adjusting repository
                discovery, Markdown loading, and the published documentation routes.
              </p>
            </div>
          </div>
          <div class="bat-line">
            <span class="bat-gutter">2</span>
            <div class="bat-code">
              <pre class="adrs-yaml-preview"><code>{configFilesPreview}</code></pre>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="standard-section-heading">
      <div>
        <p class="eyebrow">Repositories</p>
        <h2>Repositories with matching documentation</h2>
      </div>
      <p class="standard-section-meta">{repositorySummaries.length} repositories visible</p>
    </section>

    <section class="docs-library-grid">
      {repositorySummaries.map((repository, index) => (
        <a class="docs-library-card docs-library-card-link" href={repository.htmlUrl}>
          <div class="docs-library-topline">
            <span class="community-card-index">{String(index + 1).padStart(2, "0")}</span>
            <span class={`docs-status-pill docs-status-${repository.status.toLowerCase().replace(/\s+/g, "-")}`}>
              {repository.status}
            </span>
          </div>

          <div class="docs-library-body">
            <p class="docs-library-type">{repository.docType}</p>
            <h3 class="docs-library-title">{repository.repository}</h3>
            <p class="docs-library-copy">{repository.summary}</p>
            <div class="docs-library-meta">
              <span>owner: {repository.owner}</span>
              <span>updated: {repository.updated || "Unknown"}</span>
              <span>files: {repository.fileCount}</span>
              <span>folders: {repository.folderCount}</span>
              <span>rules: {repository.ruleCount}</span>
              <span>roots: {repository.roots.join(", ") || "None"}</span>
            </div>
            <span class="community-card-link">
              Open repository
            </span>
          </div>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
