{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/github-gcs-astro-seed/catalog.schema.json",
  "title": "GitHub GCS Astro Seed Catalog",
  "type": "object",
  "required": ["schemaVersion", "site", "routes", "datasets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "object",
        "required": ["path"],
        "properties": { "path": { "const": "/" } }
      },
      "items": { "$ref": "#/$defs/route" }
    },
    "datasets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/source" },
          {
            "oneOf": [
              { "type": "array" },
              {
                "type": "object",
                "not": { "required": ["$source"] }
              }
            ]
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$source"],
      "properties": {
        "$source": { "type": "string", "pattern": "^(https?://|gs://)" },
        "$fallback": { "type": "string", "pattern": "^gs://" }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "label", "template", "dataset", "intro", "view"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "path": { "type": "string", "pattern": "^/$|^/(?:[a-z0-9][a-z0-9-]*/)+$" },
        "label": { "type": "string", "minLength": 1 },
        "template": { "const": "catalog" },
        "dataset": { "type": "string", "minLength": 1 },
        "intro": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "summary"],
          "properties": {
            "eyebrow": { "type": "string" },
            "title": { "type": "string", "minLength": 1 },
            "summary": { "type": "string", "minLength": 1 }
          }
        },
        "view": {
          "type": "object",
          "additionalProperties": false,
          "required": ["titleField", "summaryField"],
          "properties": {
            "collection": { "type": "string", "minLength": 1 },
            "titleField": { "type": "string", "minLength": 1 },
            "summaryField": { "type": "string", "minLength": 1 },
            "tagsField": { "type": "string", "minLength": 1 },
            "urlField": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
